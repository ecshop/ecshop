{
    "name": "ecshop/ecshop",
    "description": "The ecshop api.",
    "keywords": ["ecshop", "laravel", "lumen"],
    "license": "Apache-2.0",
    "type": "project",
    "require": {
        "php": "^8.0.2",
        "laravel/lumen-framework": "^8.3.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "api/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
