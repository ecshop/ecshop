{
    "name": "ecshop/ecshop",
    "description": "the new ecshop",
    "type": "project",
    "keywords": [
        "ecshop",
        "thinkphp",
        "php"
    ],
    "homepage": "http://www.ecshop.com/",
    "require": {
        "php": "^7.1",
        "topthink/framework": "^6.0",
        "topthink/think-orm": "^2.0"
    },
    "require-dev": {
        "symfony/var-dumper": "^4.2",
        "topthink/think-trace":"^1.0"
    },
    "autoload": {
        "psr-4": {
            "app\\": "app/"
        }
    },
    "config": {
        "preferred-install": "dist"
    },
    "scripts": {
        "post-autoload-dump": [
            "@php artisan service:discover",
            "@php artisan vendor:publish"
        ]
    }
}
