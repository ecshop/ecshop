{
    "name": "ecshop/ecshop",
    "type": "project",
    "description": "e-commerce Management System.",
    "keywords": ["ecshop", "php", "mysql", "shop", "laravel"],
    "license": "Apache-2.0",
    "require": {
        "php": "^8.1",
        "aliyuncs/oss-sdk-php": "^2.6",
        "endroid/qr-code": "^4.8",
        "guzzlehttp/guzzle": "^7.2",
        "focite/laravel-auth": "^1.0",
        "focite/laravel-captcha": "^1.0",
        "focite/laravel-generator": "^1.0",
        "focite/laravel-image": "^1.0",
        "laravel/framework": "^10.10",
        "laravel/octane": "^2.0",
        "laravel/sanctum": "^3.2",
        "laravel/tinker": "^2.8",
        "overtrue/laravel-easy-sms": "^2.1",
        "overtrue/laravel-pinyin": "^5.0",
        "overtrue/laravel-socialite": "^4.0",
        "overtrue/laravel-wechat": "^7.2",
        "phpoffice/phpspreadsheet": "^1.29",
        "workerman/gateway-worker": "^3.1",
        "yansongda/laravel-pay": "^3.5"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^7.0",
        "phpunit/phpunit": "^10.1",
        "spatie/laravel-ignition": "^2.0",
        "zircote/swagger-php": "^4.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "App\\Support\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
